{
  "expo": {
    "name": "Ma Bible",
    "slug": "ma-bible",
    "version": "1.0.0",
    "scheme": "mabible",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B2D0E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.votrenom.mabible"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6B2D0E"
      },
      "package": "com.votrenom.mabible"
    },
    "plugins": [
      "expo-router"
    ]
  }
}